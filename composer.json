{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "babdev/pagerfanta-bundle": "^4.0",
        "doctrine/doctrine-bundle": "^2.11",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^2.17|^3.0",
        "knplabs/knp-time-bundle": "^2.2",
        "league/commonmark": "^2.4",
        "pagerfanta/doctrine-orm-adapter": "^4.0",
        "pagerfanta/twig": "^4.0",
        "phpdocumentor/reflection-docblock": "^6.0",
        "phpstan/phpdoc-parser": "^2.3",
        "stof/doctrine-extensions-bundle": "^1.10",
        "symfony/asset": "7.4.*",
        "symfony/asset-mapper": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.4",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/stimulus-bundle": "^2.32",
        "symfony/stopwatch": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/ux-chartjs": "^2.0",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*",
        "twig/extra-bundle": "^3.8",
        "twig/markdown-extra": "^3.8",
        "twig/string-extra": "^3.8",
        "twig/twig": "^3.8"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.5",
        "rector/rector": "^2.3",
        "symfony/debug-bundle": "7.4.*",
        "symfony/maker-bundle": "^1.50",
        "symfony/var-dumper": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "zenstruck/foundry": "^1.37|^2.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
